<Window x:Class="WpfIntro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Generador de Personajes"
    Height="1000"
    Width="1000">
    <ScrollViewer>
    <StackPanel Margin="20">
        <TextBlock Text="Nombre del personaje:"/>
        <TextBox x:Name="txtNombre"/>
        <TextBlock Text="Clase:"/>

        <ComboBox x:Name="cmbRaza">
        <ComboBoxItem Content="Night"/>
        <ComboBoxItem Content="Megami"/>
        <ComboBoxItem Content="Tyrant"/>
        </ComboBox>

        <CheckBox x:Name="chkFisico"
        Content="Fisico"/>
        <CheckBox x:Name="chkMagia"
        Content="Magia"/>


        <Button Content="Generar"
            Click="BtnGenerar_Click"/>
            
            <Image x:Name="imgPersonaje"
            Width="900"
            Height="900"/>
            <TextBlock x:Name="txtResultado"/>
        </StackPanel>
    </ScrollViewer>
</Window>
